# Helm packaged charts
*.tgz

# Helm dependency directories (generated by helm dependency build/update)
charts/

# Helm lock file (optional: commit it only if you want strict reproducibility)
Chart.lock

# Helm local cache and config (when running helm locally)
.helm/
.helmcache/
.helmconfig/

# Temporary files
*.tmp
*.bak
*.swp

# OS-specific files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/
*.iml

# Logs
*.log


# java target folder
it/target
